{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI ToReder",
  "version": "0.1.0",
  "identifier": "com.aitoreder.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI ToReder",
        "width": 1360,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "resources": [
      "binaries/aitoreder-backend/**"
    ]
  }
}
